# =============================================================================
# SvelteKit app (.env) — copy to .env and fill every non-comment line you need
# =============================================================================

# Why: The browser and server Supabase clients need your project API endpoint so
# auth, habits, and PushSubscription rows talk to the correct backend.
# Where: Supabase Dashboard → Project Settings → API → Project URL
PUBLIC_SUPABASE_URL=

# Why: Safe, public key used client-side and in server routes; RLS policies enforce
# what each user can read/write. Never put the service_role key here.
# Where: Supabase Dashboard → Project Settings → API → anon public key
PUBLIC_SUPABASE_ANON_KEY=

# Why: Auth helpers build redirect URLs (OAuth sign-in return, email links) from this
# base. Wrong value = callbacks land on the wrong host or fail after login.
# Use no trailing slash. Local: http://localhost:5173 | Prod: https://yourdomain.com
PUBLIC_APP_URL=

# Why: Only if your IdP or hosting setup cannot use the default
# {PUBLIC_APP_URL}/auth/callback (e.g. custom domain or proxy path).
# PUBLIC_AUTH_CALLBACK_URL=

# Why: Only if password reset emails must open a URL other than
# {PUBLIC_APP_URL}/reset-password.
# PUBLIC_PASSWORD_RESET_URL=

# Why: Browser push (Profile) uses this with the Push API; the service worker subscribes
# with this public key. Generate a pair: npx web-push generate-vapid-keys — keep the
# private key on the server / Edge Function secrets only; this value is the public half.
# PUBLIC_VAPID_PUBLIC_KEY=

# Why: svelte.config.js reads this so a "mobile" web build can differ from the default
# (e.g. Capacitor bundle). Omit for normal dev and production web.
# BUILD_TARGET=mobile

# =============================================================================
# Supabase Edge Function "push-reminders" — do not put these in the app .env.
# Set secrets with: supabase secrets set KEY=value
# =============================================================================

# SUPABASE_URL — Why: Tells the function which Supabase project to attach to. Supabase
# injects this automatically when the function runs; you normally do not set it yourself.

# SUPABASE_SERVICE_ROLE_KEY — Why: Server-side admin access so the function can read
# habits, completions, and subscriptions regardless of RLS. Auto-injected on Supabase;
# never put this key in PUBLIC_ vars or commit it.

# FCM_SERVER_KEY — Why: Authenticates requests to Firebase Cloud Messaging’s legacy HTTP
# API so Android tokens in PushSubscription can receive reminder pushes. Skip if you
# are not sending Android pushes from this function.

# VAPID_PRIVATE_KEY — Why: Signs outgoing Web Push requests; must stay secret and live
# only in Edge secrets (or your own push server).

# VAPID_PUBLIC_KEY — Why: Must match the key users subscribed with (same pair as
# PUBLIC_VAPID_PUBLIC_KEY in the app, if you use web push end-to-end).

# VAPID_SUBJECT — Why: Contact URI for the push service (e.g. mailto:you@example.com);
# required by the Web Push protocol when sending with VAPID.
