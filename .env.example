# =============================================================================
# SvelteKit app — copy to .env and fill values (this file stays empty placeholders)
# =============================================================================

# Supabase Dashboard → Project Settings → API → Project URL
PUBLIC_SUPABASE_URL=

# Supabase Dashboard → Project Settings → API → anon public key
PUBLIC_SUPABASE_ANON_KEY=

# No trailing slash. Local dev often: http://localhost:5173
PUBLIC_APP_URL=

# Optional: only if you cannot use {PUBLIC_APP_URL}/auth/callback
PUBLIC_AUTH_CALLBACK_URL=

# Optional: only if reset emails must not use {PUBLIC_APP_URL}/reset-password
PUBLIC_PASSWORD_RESET_URL=

# Optional: web push (public half of VAPID pair)
PUBLIC_VAPID_PUBLIC_KEY=

# Optional: svelte.config.js mobile build (e.g. Capacitor)
BUILD_TARGET=

# =============================================================================
# Supabase Edge Functions — usually set via: supabase secrets set KEY=value
# (Uncomment and fill here only for local CLI / testing.)
# =============================================================================

SUPABASE_URL=

SUPABASE_SERVICE_ROLE_KEY=

FCM_SERVER_KEY=

VAPID_PRIVATE_KEY=

VAPID_PUBLIC_KEY=

VAPID_SUBJECT=

# =============================================================================
# Razorpay (Pro) — production: Edge secrets; optional local testing below
# =============================================================================

RAZORPAY_KEY_ID=

RAZORPAY_KEY_SECRET=

RAZORPAY_PLAN_ID=

RAZORPAY_WEBHOOK_SECRET=

RAZORPAY_SUBSCRIPTION_TOTAL_COUNT=
