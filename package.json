{
	"name": "strida",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:mobile": "cross-env BUILD_TARGET=mobile vite build",
		"preview": "vite preview",
		"db:seed": "npx supabase db query --linked --file supabase/seed.sql",
		"db:seed:local": "npx supabase db query --local --file supabase/seed.sql",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"lint": "eslint . && prettier --check .",
		"format": "prettier --write .",
		"postbuild": "node scripts/postbuild.js",
		"deploy": "npm run build && surge build",
		"cap:prepare": "npm run build:mobile && npx cap sync android",
		"cap:sync": "npx cap sync android",
		"cap:copy": "npx cap copy android",
		"cap:open": "npx cap open android",
		"cap:run": "npm run cap:sync && npx cap run android"
	},
	"devDependencies": {
		"@capacitor/cli": "^8.2.0",
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.39.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.7.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.48.5",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"@types/node": "^24",
		"bits-ui": "^2.16.5",
		"clsx": "^2.1.1",
		"cross-env": "^10.1.0",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.0",
		"globals": "^16.5.0",
		"layerchart": "^2.0.0-next.27",
		"mode-watcher": "^1.1.0",
		"playwright": "^1.59.1",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.7.1",
		"svelte": "^5.43.8",
		"svelte-check": "^4.3.4",
		"svelte-sonner": "^1.0.7",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.17",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^7.2.2",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@capacitor/android": "^8.2.0",
		"@capacitor/core": "^8.2.0",
		"@capacitor/push-notifications": "^8.0.3",
		"@supabase/ssr": "^0.8.0",
		"@supabase/supabase-js": "^2.89.0",
		"jspdf": "^4.2.1"
	}
}
